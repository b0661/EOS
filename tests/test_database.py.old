"""Pytest tests for database persistence module.

Tests the abstract Database interface and concrete implementations (LMDB, SQLite).
Also tests the database integration with DataSequence/DataProvider classes.
"""

import pickle
import shutil
import tempfile
import time
from pathlib import Path
from typing import Iterator, List, Optional, Type

import pytest
from pydantic import Field

from akkudoktoreos.core.coreabc import get_database
from akkudoktoreos.core.dataabc import (
    DataProvider,
    DataRecord,
    DataSequence,
)
from akkudoktoreos.core.database import (
    Database,
    LMDBDatabase,
    SQLiteDatabase,
)
from akkudoktoreos.utils.datetimeutil import (
    DateTime,
    Duration,
    to_datetime,
    to_duration,
)

# ==================== Test Fixtures ====================

@pytest.fixture
def temp_dir():
    """Create a temporary directory for test databases."""
    temp_path = Path(tempfile.mkdtemp())
    yield temp_path
    # Cleanup after test
    shutil.rmtree(temp_path, ignore_errors=True)


@pytest.fixture(params=["LMDB", "SQLite"])
def database_provider(request) -> str:
    """Parametrized fixture to test all database backends."""
    return request.param


@pytest.fixture
def database_instance(config_eos, database_provider: str, temp_dir: Path) -> Iterator[Database]:
    """Create a database instance for testing."""
    # Database is a singleton - ensure we get a new one
    #Database.reset_instance()
    #LMDBDatabase.reset_instance()
    #SQLiteDatabase.reset_instance()

    config_eos.database.compression_level = 6
    config_eos.database.provider = database_provider
    db = get_database()
    assert db.is_open is True
    assert db.provider_id() == config_eos.database.provider

    yield db

    # teardown
    config_eos.database.provider = None
    assert db.provider_id() == "None"



# ==================== Test Data Models ====================

class SampleDataRecord(DataRecord):
    """Test implementation of DataRecord."""
    temperature: float = Field(default=0.0)
    humidity: float = Field(default=0.0)
    pressure: float = Field(default=0.0)


class SampleDataSequence(DataSequence):
    """Test implementation of DataSequence with database support."""
    records: List[SampleDataRecord] = Field(default_factory=list)

    def db_namespace(self) -> str:
        return "SampleDataSequence"


class SampleDataProvider(DataProvider):
    """Test implementation of DataProvider with database support."""
    records: List[SampleDataRecord] = Field(default_factory=list)

    def provider_id(self) -> str:
        return "SampleDataProvider"

    def enabled(self) -> bool:
        return True

    def _update_data(self, force_update=False) -> None:
        pass


# ==================== Database Backend Tests ====================

class TestDatabase:
    """Test abstract Database interface and implementations."""

    def test_database_creation(self, config_eos, database_provider):
        """Test database creation and initialization."""
        config_eos.database.compression_level = 6
        config_eos.database.provider = database_provider
        db = get_database()

        assert db.storage_path == config_eos.general.data_folder_path / "db" / db._db.__class__.__name__.lower()
        assert db.compression is True
        assert db.compression_level == 6
        assert db.is_open is True

    def test_database_open_close(self, database_instance):
        """Test opening and closing database connection."""
        assert database_instance.is_open is True
        assert database_instance._db.connection is not None

        database_instance.close()
        assert database_instance._db.is_open is False

    def test_save_and_load_single_record(self, database_instance):
        """Test saving and loading a single record."""
        key = b'2024-01-01T00:00:00+00:00'
        value = b'test_data_12345'

        assert database_instance.is_open is True

        # Save
        database_instance.save_records([(key, value)])

        # Load
        records = list(database_instance.iterate_records(key, key + b'\xff'))
        assert len(records) == 1
        assert records[0] == (key, value)

    def test_save_multiple_records(self, database_instance):
        """Test saving and loading multiple records."""
        records = [
            (b'2024-01-01T00:00:00+00:00', b'data1'),
            (b'2024-01-02T00:00:00+00:00', b'data2'),
            (b'2024-01-03T00:00:00+00:00', b'data3'),
        ]

        # Save all
        saved = database_instance.save_records(records)
        assert saved == len(records)

        # Load all
        loaded = list(database_instance.iterate_records())
        assert len(loaded) == len(records)

        for (expected_key, expected_value), (loaded_key, loaded_value) in zip(records, loaded):
            assert loaded_key == expected_key
            assert loaded_value == expected_value

    def test_load_records_with_range(self, database_instance):
        """Test loading records within a specific key range."""
        records = [
            (b'2024-01-01T00:00:00+00:00', b'data1'),
            (b'2024-01-02T00:00:00+00:00', b'data2'),
            (b'2024-01-03T00:00:00+00:00', b'data3'),
            (b'2024-01-04T00:00:00+00:00', b'data4'),
            (b'2024-01-05T00:00:00+00:00', b'data5'),
        ]

        saved = database_instance.save_records(records)
        assert saved == len(records)

        # Load range [2024-01-02, 2024-01-04)
        start_key = b'2024-01-02T00:00:00+00:00'
        end_key = b'2024-01-04T00:00:00+00:00'
        loaded = list(database_instance.iterate_records(start_key, end_key))

        assert len(loaded) == 2
        assert loaded[0][0] == b'2024-01-02T00:00:00+00:00'
        assert loaded[1][0] == b'2024-01-03T00:00:00+00:00'

    def test_delete_record(self, database_instance):
        """Test deleting a record."""
        key = b'2024-01-01T00:00:00+00:00'
        value = b'test_data'

        # Save
        database_instance.save_records([(key, value)])
        assert database_instance.count_records() == 1

        # Delete
        result = database_instance.delete_records([key])
        assert result == 1
        assert database_instance.count_records() == 0

        # Try to delete non-existent record
        result = database_instance.delete_records([key])
        assert result == 0

    def test_count_records(self, database_instance):
        """Test counting records."""
        assert database_instance.count_records() == 0

        # Add records
        for i in range(10):
            key = f'2024-01-{i+1:02d}T00:00:00+00:00'.encode()
            database_instance.save_records([(key, b'data')])

        assert database_instance.count_records() == 10

    def test_get_key_range(self, database_instance):
        """Test getting min and max keys."""
        # Empty database
        min_key, max_key = database_instance.get_key_range()
        assert min_key is None
        assert max_key is None

        # Add records
        keys = [
            b'2024-01-01T00:00:00+00:00',
            b'2024-01-05T00:00:00+00:00',
            b'2024-01-03T00:00:00+00:00',
        ]
        for key in keys:
            database_instance.save_records([(key, b'data')])

        min_key, max_key = database_instance.get_key_range()
        assert min_key == b'2024-01-01T00:00:00+00:00'
        assert max_key == b'2024-01-05T00:00:00+00:00'

    def test_iterate_records_forward(self, database_instance):
        """Test iterating records in forward order."""
        keys = [
            b'2024-01-01T00:00:00+00:00',
            b'2024-01-02T00:00:00+00:00',
            b'2024-01-03T00:00:00+00:00',
        ]
        for key in keys:
            database_instance.save_records([(key, b'data')])

        result = list(database_instance.iterate_records())
        result_keys = [k for k, v in result]

        assert result_keys == keys

    def test_iterate_records_reverse(self, database_instance):
        """Test iterating records in reverse order."""
        keys = [
            b'2024-01-01T00:00:00+00:00',
            b'2024-01-02T00:00:00+00:00',
            b'2024-01-03T00:00:00+00:00',
        ]
        for key in keys:
            database_instance.save_records([(key, b'data')])

        result = list(database_instance.iterate_records(reverse=True))
        result_keys = [k for k, v in result]

        assert result_keys == list(reversed(keys))

    def test_compression(self, config_eos, database_provider, temp_dir):
        """Test data compression."""

        # Large repetitive data (highly compressible)
        large_data = b'A' * 10000

        config_eos.database.provider = database_provider

        # Database with compression
        config_eos.database.compression_level = 9
        serialized_compressed = get_database().serialize_data(large_data)
        deserialized_compressed = get_database().deserialize_data(serialized_compressed)

        # Database without compression
        config_eos.database.compression_level = 0
        serialized_uncompressed = get_database().serialize_data(large_data)
        deserialized_uncompressed = get_database().deserialize_data(serialized_uncompressed)

        # Compressed should be smaller
        assert len(serialized_compressed) < len(serialized_uncompressed)

        # Verify decompression works
        assert deserialized_compressed == large_data
        assert deserialized_uncompressed == large_data

    def test_flush(self, database_instance):
        """Test flushing writes to storage."""
        key = b'2024-01-01T00:00:00+00:00'
        value = b'test_data'

        database_instance.save_records([(key, value)])
        database_instance.flush()

        # Data should be persisted
        loaded = list(database_instance.iterate_records())
        assert len(loaded) == 1
        assert loaded[0] == (key, value)

    def test_backend_stats(self, database_instance):
        """Test getting backend-specific statistics."""
        stats = database_instance.get_backend_stats()

        assert 'backend' in stats
        assert isinstance(stats, dict)

        # Add some data
        for i in range(10):
            key = f'2024-01-{i+1:02d}T00:00:00+00:00'.encode()
            database_instance.save_records([(key, b'data' * 100)])

        stats = database_instance.get_backend_stats()
        assert stats is not None


# ==================== DataSequence Database Protocol Tests ====================

class TestDataSequenceDatabaseProtocol:
    """Test database integration with refactored DataSequence."""

    def test_sequence_len_with_database(self, config_eos, database_instance):
        """Test __len__ returns correct count including database and memory-only records."""

        class SampleSequenceNoAutoLoad(SampleDataSequence):
            """Subclass that disables initial DB loading for testing memory-only inserts."""
            def _db_load_initial_window(self, center: Optional[DateTime]) -> int:
                # Override to skip loading from DB
                return 0

            def db_ensure_loaded(
                self,
                start_datetime: Optional[DateTime] = None,
                end_datetime: Optional[DateTime] = None,
                *,
                center_datetime: Optional[DateTime] = None,
            ) -> None:
                return  # skip any lazy loading

        sequence = SampleSequenceNoAutoLoad()
        sequence.load()  # DB enabled, but no records are loaded

        base_time = to_datetime("2024-01-01T00:00:00Z")

        # Add 10 records to memory and save to database
        for i in range(10):
            record = SampleDataRecord(
                date_time=base_time.add(hours=i),
                temperature=20.0 + i
            )
            sequence.insert_by_datetime(record)

        # Save all to DB and clear memory
        sequence.db_save_records()
        assert len(sequence.records) == 10  # memory stays

        # DB-only scenario
        db_count = sequence.db_count_records()
        mem_count = len(sequence.records)
        assert db_count == 10
        assert mem_count == 10
        assert len(sequence) == 10

        # Add 5 new records in memory only
        for i in range(10, 15):
            record = SampleDataRecord(
                date_time=base_time.add(hours=i),
                temperature=20.0 + i
            )
            sequence.insert_by_datetime(record)

        # DB + memory scenario
        storage_count2 = sequence.database.count_records(namespace='SampleDataSequence')
        mem_count2 = len(sequence.records)
        db_count2 = sequence.db_count_records()
        total_len = len(sequence)

        # Check counts
        assert storage_count2 == 10         # Storage-only records
        assert mem_count2 == 15             # Memory-only records
        assert db_count2 == 15              # Storage + memory
        assert total_len == 15              # Total includes both DB and memory

    def test_sequence_auto_save_and_initial_window(self, config_eos, database_instance):
        """Test behavior with auto-save enabled and full initial DB load."""

        class TestSequenceAutoSave(SampleDataSequence):
            """Uses default full initial window and allows auto-save to trigger."""
            records: list[SampleDataRecord] = Field(default_factory=list)

            def db_namespace(self) -> str:
                return "TestSequenceAutoSave"

        # Enable auto-save with a small threshold
        config_eos.database.max_records_in_memory = 5

        sequence = TestSequenceAutoSave()
        sequence.load()  # Triggers full initial load (window=None)

        base_time = to_datetime("2024-01-01T00:00:00Z")

        # Insert 8 records → exceeds max_records_in_memory → auto-save triggers
        for i in range(8):
            record = SampleDataRecord(
                date_time=base_time.add(hours=i),
                temperature=20.0 + i
            )
            sequence.insert_by_datetime(record)

        sequence.db_autosave()

        # After auto-save, memory should be capped at max_records_in_memory
        assert len(sequence.records) <= config_eos.database.max_records_in_memory

        # DB should contain saved records
        db_count = sequence.database.count_records(namespace=sequence.db_namespace())
        assert db_count >= 3  # the oldest 3 records should have been saved

        # Add a few more records to trigger another auto-save
        for i in range(8, 11):
            record = SampleDataRecord(
                date_time=base_time.add(hours=i),
                temperature=20.0 + i
            )
            sequence.insert_by_datetime(record)

        # DB + memory counts
        db_count2 = sequence.database.count_records(namespace=sequence.db_namespace())
        mem_count2 = len(sequence.records)
        total_len = len(sequence)

        # The total number of records should match DB + memory
        assert total_len == db_count2 + mem_count2
        assert mem_count2 <= config_eos.database.max_records_in_memory

    def test_load(self, database_instance):
        """Test initializing database with a sequence."""
        sequence = SampleDataSequence()

        assert sequence.load() is True
        assert sequence.db_enabled is True
        assert sequence.database == database_instance

    def test_save_and_load_records(self, database_instance):
        """Test saving and loading data records."""
        sequence = SampleDataSequence()
        sequence.load()

        base_time = to_datetime("2024-01-01T00:00:00Z")
        for i in range(10):
            sequence.insert_by_datetime(
                SampleDataRecord(
                    date_time=base_time.add(hours=i),
                    temperature=20.0 + i,
                    humidity=60.0 + i,
                    pressure=1013.0 + i,
                )
            )

        saved_count = sequence.db_save_records(clear_memory=False)
        assert saved_count == 10

        sequence.records.clear()
        assert not sequence.records

        loaded = sequence.db_load_records()
        assert loaded == 10
        assert len(sequence.records) == 10

        for i, record in enumerate(sequence.records):
            assert record.temperature == 20.0 + i

    def test_save_with_datetime_range(self, database_instance):
        """Test saving only a specific datetime range."""
        sequence = SampleDataSequence()
        sequence.load()

        base_time = to_datetime("2024-01-01T00:00:00Z")
        for i in range(10):
            sequence.insert_by_datetime(
                SampleDataRecord(
                    date_time=base_time.add(hours=i),
                    temperature=20.0 + i,
                )
            )

        start_dt = base_time.add(hours=3)
        end_dt = base_time.add(hours=7)

        saved = sequence.db_save_records(
            clear_memory=False,
            start_datetime=start_dt,
            end_datetime=end_dt,
        )

        storage_count = sequence.database.count_records(namespace='SampleDataSequence')
        db_count = sequence.db_count_records()

        assert saved == 4
        assert storage_count == 4
        assert db_count == 10

    def test_load_with_datetime_range(self, database_instance):
        """Test loading a bounded datetime range."""
        sequence = SampleDataSequence()
        sequence.load()

        base_time = to_datetime("2024-01-01T00:00:00Z")
        for i in range(10):
            sequence.insert_by_datetime(
                SampleDataRecord(
                    date_time=base_time.add(hours=i),
                    temperature=20.0 + i,
                )
            )

        sequence.db_save_records(clear_memory=True)
        assert sequence.db_count_records() == 10

        start_dt = base_time.add(hours=3)
        end_dt = base_time.add(hours=7)

        loaded = sequence.db_load_records(start_datetime=start_dt, end_datetime=end_dt)

        assert loaded == 4
        assert len(sequence.records) == 4
        assert sequence.records[0].temperature == 23.0
        assert sequence.records[-1].temperature == 26.0

    def test_db_ensure_loaded_staged_expansion(self, database_instance):
        """Test staged loading via db_ensure_loaded."""
        sequence = SampleDataSequence()
        sequence.load()

        base_time = to_datetime("2024-01-01T00:00:00Z")
        for i in range(48):
            sequence.insert_by_datetime(
                SampleDataRecord(
                    date_time=base_time.add(hours=i),
                    temperature=20.0 + i,
                )
            )

        sequence.db_save_records(clear_memory=True)
        assert not sequence.records

        start = base_time.add(hours=10)
        end = base_time.add(hours=20)

        sequence.db_ensure_loaded(start, end)
        assert all(start <= r.date_time < end for r in sequence.records)

    def test_auto_save_trigger(self, config_eos, database_instance):
        """Test auto-save triggers when memory threshold is exceeded."""
        # Configure sequence to auto-save when memory exceeds threshold
        config_eos.database.max_records_in_memory = 10

        sequence = SampleDataSequence()
        sequence.load()  # db_enabled will be True automatically

        # Add 15 records; threshold is 10, so oldest should auto-save
        base_time = to_datetime('2024-01-01T00:00:00Z')
        for i in range(15):
            record = SampleDataRecord(
                date_time=base_time.add(hours=i),
                temperature=20.0 + i
            )
            sequence.insert_by_datetime(record)
            # Records in memory should be trimmed to max_records_in_memory
            assert len(sequence.records) <= config_eos.database.max_records_in_memory

        sequence.db_autosave()

        # Total records in the database should include auto-saved older records
        total_in_db = sequence.db_count_records()
        assert total_in_db > 0

        # Verify that the latest records are still in memory and sorted
        for i in range(len(sequence.records) - 1):
            dt0 = to_datetime(sequence.records[i].date_time)
            dt1 = to_datetime(sequence.records[i + 1].date_time)
            assert dt0 < dt1

    def test_delete_by_datetime_memory_only(self):
        """Deleting without DB enabled only mutates memory."""
        sequence = SampleDataSequence()

        base_time = to_datetime("2024-01-01T00:00:00Z")
        for i in range(5):
            sequence.insert_by_datetime(
                SampleDataRecord(
                    date_time=base_time.add(hours=i),
                    temperature=20.0,
                )
            )

        deleted = sequence.delete_by_datetime(
            start_datetime=base_time.add(hours=1),
            end_datetime=base_time.add(hours=4),
        )

        assert deleted == 3
        assert len(sequence.records) == 2

    def test_db_delete_records_only(self, database_instance):
        """db_delete_records deletes from DB but not memory."""
        sequence = SampleDataSequence()
        sequence.load()

        base_time = to_datetime("2024-01-01T00:00:00Z")
        for i in range(6):
            sequence.insert_by_datetime(
                SampleDataRecord(
                    date_time=base_time.add(hours=i),
                    temperature=20.0,
                )
            )

        sequence.db_save_records(clear_memory=False)
        assert len(sequence.records) == 6

        deleted = sequence.db_delete_records(
            clear_memory=False,
            start_datetime=base_time.add(hours=2),
            end_datetime=base_time.add(hours=5),
        )

        assert deleted == 3
        assert len(sequence.records) == 6
        assert sequence.db_count_records() == 3

    def test_db_initial_time_window_used(self, database_instance, monkeypatch):
        """Initial load window is used when no window is specified."""
        class WindowedSequence(SampleDataSequence):
            def db_initial_time_window(self):
                return to_duration("2 hours")

        sequence = WindowedSequence()
        sequence.load()

        base_time = to_datetime("2024-01-01T00:00:00Z")
        for i in range(24):
            sequence.insert_by_datetime(
                SampleDataRecord(
                    date_time=base_time.add(hours=i),
                    temperature=20.0,
                )
            )

        sequence.db_save_records(clear_memory=True)
        sequence.get_nearest_by_datetime(base_time.add(hours=12))

        assert len(sequence.records) <= 5  # bounded initial load

    def test_db_vacuum(self, database_instance):
        """Test vacuuming old records from database only, memory-independent."""
        sequence = SampleDataSequence()
        sequence.load()

        # Create records over 10 days
        base_time = to_datetime('2024-01-01T00:00:00Z')
        for i in range(240):
            sequence.insert_by_datetime(SampleDataRecord(
                date_time=base_time.add(hours=i),
                temperature=20.0
            ))

        # Save all records and clear memory
        sequence.db_save_records(clear_memory=True)
        assert sequence.db_count_records() == 240
        assert len(sequence.records) == 0

        # Vacuum: keep only last 5 days
        keep_hours = 5*24
        deleted = sequence.db_vacuum(keep_hours=keep_hours)

        expected_remaining = keep_hours
        total_in_db = sequence.db_count_records()
        assert total_in_db == expected_remaining
        assert deleted == 240 - expected_remaining

    def test_db_datetime_range(self, database_instance):
        """Test getting datetime range from database."""
        sequence = SampleDataSequence()
        sequence.load()

        # Empty database
        min_dt, max_dt = sequence.db_datetime_range()
        assert min_dt is None
        assert max_dt is None

        # Add records
        base_time = to_datetime('2024-01-01T00:00:00Z')
        for i in [0, 5, 10]:
            record = SampleDataRecord(
                date_time=base_time.add(hours=i),
                temperature=20.0
            )
            sequence.insert_by_datetime(record)
        sequence.db_save_records(clear_memory=True)

        # Check range
        min_dt, max_dt = sequence.db_datetime_range()
        assert min_dt == base_time
        assert max_dt == base_time.add(hours=10)

    def test_db_stats(self, database_instance):
        """Database stats reflect refactored model."""
        sequence = SampleDataSequence()
        sequence.load()

        stats = sequence.db_get_stats()
        assert stats['enabled'] is True
        assert 'backend' in stats
        assert 'path' in stats
        assert 'memory_records' in stats
        assert 'total_records' in stats
        assert 'compression_enabled' in stats
        assert 'datetime_range' in stats

    def test_db_flush(self, database_instance):
        """Test flushing database writes."""
        sequence = SampleDataSequence()
        assert sequence.load() == True
        assert sequence.db_count_records() == 0

        # Add record
        record = SampleDataRecord(
            date_time=to_datetime('2024-01-01T00:00:00Z'),
            temperature=20.0
        )
        sequence.insert_by_datetime(record)
        sequence.db_save_records(clear_memory=False)

        # Flush
        sequence.db_flush()

        # Should be persisted
        assert sequence.db_count_records() == 1


# ==================== Backend-Specific Tests ====================

class TestLMDBDatabase:
    """Test LMDB-specific features."""

    def test_lmdb_compact(self, config_eos):
        """Test LMDB compaction."""
        config_eos.database.compression_level = 0
        db = LMDBDatabase()
        db.open()

        # Add lots of data
        for i in range(1000):
            key = f'2024-01-01T{i:06d}:00:00+00:00'.encode()
            value = b'X' * 1000
            db.save_records([(key, value)])

        # Delete half
        for i in range(500):
            key = f'2024-01-01T{i:06d}:00:00+00:00'.encode()
            db.delete_records([key])

        # Get stats before compaction
        stats_before = db.get_backend_stats()

        # Compact
        db.compact()

        # Get stats after compaction
        stats_after = db.get_backend_stats()

        # Should still have 500 records
        assert db.count_records() == 500

        db.close()


class TestSQLiteDatabase:
    """Test SQLite-specific features."""

    def test_sqlite_vacuum(self, config_eos):
        """Test SQLite vacuum."""
        config_eos.database.compression_level = 0
        db = SQLiteDatabase()
        db.open()

        # Add data
        records = []
        for i in range(100):
            key = f'2024-01-{i+1:02d}T00:00:00+00:00'.encode()
            value = b'data' * 100
            records.append((key, value))
        db.save_records(records)

        # Delete some
        keys = []
        for i in range(50):
            key = f'2024-01-{i+1:02d}T00:00:00+00:00'.encode()
            keys.append(key)
        db.delete_records(keys)

        # Vacuum
        db.vacuum()

        # Should still have 50 records
        assert db.count_records() == 50

        db.close()


# ==================== Integration Tests ====================

class TestIntegration:
    """Integration tests with full workflow."""

    def test_full_workflow(self, config_eos, database_instance):
        """Test complete workflow: save, load, update, vacuum."""
        config_eos.database.max_records_in_memory=50
        sequence = SampleDataSequence()
        sequence.load()

        # Step 1: Add initial data
        base_time = to_datetime('2024-01-01T00:00:00Z')
        for i in range(100):
            record = SampleDataRecord(
                date_time=base_time.add(hours=i),
                temperature=20.0 + i * 0.1,
                humidity=60.0
            )
            sequence.insert_by_datetime(record)

        # Step 2: Verify auto-save happened
        storage_count = sequence.database.count_records(namespace='SampleDataSequence')
        mem_count = len(sequence.records)
        db_count = sequence.db_count_records()
        total_len = len(sequence)
        assert storage_count == 50
        assert mem_count == 50
        assert db_count == 100
        assert total_len == 100

        # Step 3: Load specific range
        sequence.records.clear()
        start_dt = base_time.add(hours=20)
        end_dt = base_time.add(hours=40)
        sequence.db_load_records(start_dt, end_dt)

        storage_count = sequence.database.count_records(namespace='SampleDataSequence')
        mem_count = len(sequence.records)
        db_count = sequence.db_count_records()
        total_len = len(sequence)
        assert storage_count == 50
        assert mem_count == 20
        assert db_count == 50
        assert total_len == 50

        # Step 4: Update records
        for record in sequence.records:
            record.humidity = 70.0
        sequence.db_save_records(clear_memory=False)

        # Step 5: Verify updates
        sequence.records.clear()
        sequence.db_load_records(start_dt, end_dt)

        for record in sequence.records:
            assert record.humidity == 70.0
        assert len(sequence.records) == 20
        assert sequence.db_count_records() == 50

        # Step 6: Vacuum old data
        cutoff = base_time.add(hours=25)
        deleted = sequence.db_vacuum(keep_datetime=cutoff)
        assert deleted == 25

        # Step 7: Verify remaining data
        remaining = sequence.db_count_records()
        assert remaining == 25

        # Step 8: Get statistics
        stats = sequence.db_get_stats()
        assert stats['total_records'] == 25

    def test_error_handling(self, config_eos):
        """Test error handling in various scenarios."""
        config_eos.database.provider = None
        sequence = SampleDataSequence()

        assert sequence.load() == False

        # Error: Using database before initialization
        with pytest.raises(RuntimeError, match="not enabled"):
            sequence.db_save_records()

        # Initialize properly
        config_eos.database.provider = "LMDB"
        assert sequence.load() == True

        # Error: Invalid vacuum parameters
        with pytest.raises(ValueError, match="Must specify either"):
            sequence.db_vacuum()

        sequence.database.close()


# ==================== Performance Tests ====================

class TestPerformance:
    """Performance and stress tests."""

    def test_large_dataset(self, config_eos, database_instance):
        """Test handling large datasets."""
        sequence = SampleDataSequence()
        sequence.load()

        # Add 10,000 records
        start = time.time()
        base_time = to_datetime('2024-01-01T00:00:00Z')
        for i in range(10000):
            record = SampleDataRecord(
                date_time=base_time.add(minutes=i),
                temperature=20.0 + (i % 100) * 0.1
            )
            sequence.insert_by_datetime(record)
            if i in (1000, 2000, 3000, 4000, 5000, 6000, 7000, 8000, 9000, 10000):
                duration = time.time() - start
                print(f"\nInserted {i} records in {duration:.2f}s ({i/duration:.0f} records/sec)")

        # Save all
        start = time.time()
        saved = sequence.db_save_records(clear_memory=True)
        duration = time.time() - start

        assert saved == 10000
        print(f"\nSaved 10,000 records in {duration:.2f}s ({saved/duration:.0f} records/sec)")

        # Load all
        start = time.time()
        loaded = sequence.db_load_records()
        duration = time.time() - start

        assert loaded == 10000
        print(f"Loaded 10,000 records in {duration:.2f}s ({loaded/duration:.0f} records/sec)")


class TestDataSequenceDatabaseProtocol2:
    """Tests for DatabaseRecordProtocolMixin using hybrid memory+DB logic."""

    # ------------------------------------------------------------------
    # Helper
    # ------------------------------------------------------------------

    def _restart_sequence(self, sequence: SampleDataSequence) -> SampleDataSequence:
        """Simulate full application restart while keeping same DB."""
        db = sequence.database
        new_seq = SampleDataSequence()
        new_seq.load()
        new_seq.database = db
        return new_seq

    # ------------------------------------------------------------------
    # Save + Reload
    # ------------------------------------------------------------------

    def test_save_and_full_reload(self, database_instance):
        sequence = SampleDataSequence()
        sequence.load()
        sequence.database = database_instance

        base = to_datetime("2024-01-01T00:00:00Z")

        for i in range(10):
            sequence.insert_by_datetime(
                SampleDataRecord(
                    date_time=base.add(hours=i),
                    temperature=20.0 + i,
                )
            )

        assert sequence.db_save_records() == 10
        assert len(sequence.records) == 10
        assert sequence.db_count_records() == 10

        # Simulate restart
        sequence = self._restart_sequence(sequence)

        loaded = sequence.db_load_records()
        assert loaded == 10
        assert len(sequence.records) == 10
        assert sequence.db_count_records() == 10

    # ------------------------------------------------------------------
    # Range Loading
    # ------------------------------------------------------------------

    def test_load_with_datetime_range(self, database_instance):
        sequence = SampleDataSequence()
        sequence.load()
        sequence.database = database_instance

        base = to_datetime("2024-01-01T00:00:00Z")

        for i in range(24):
            sequence.insert_by_datetime(
                SampleDataRecord(
                    date_time=base.add(hours=i),
                    temperature=15.0 + i,
                )
            )

        sequence.db_save_records(clear_memory=True)

        # restart
        sequence = self._restart_sequence(sequence)

        start = base.add(hours=5)
        end = base.add(hours=10)

        loaded = sequence.db_load_records(start_datetime=start, end_datetime=end)

        assert loaded == 5
        assert len(sequence.records) == 5
        assert sequence.db_count_records() == 24

    # ------------------------------------------------------------------
    # No duplication when loading same window twice
    # ------------------------------------------------------------------

    def test_no_duplicate_on_repeated_window_load(self, database_instance):
        sequence = SampleDataSequence()
        sequence.load()
        sequence.database = database_instance

        base = to_datetime("2024-01-01T00:00:00Z")

        for i in range(10):
            sequence.insert_by_datetime(
                SampleDataRecord(
                    date_time=base.add(hours=i),
                    temperature=20.0,
                )
            )

        sequence.db_save_records(clear_memory=True)
        sequence = self._restart_sequence(sequence)

        start = base
        end = base.add(hours=5)

        loaded1 = sequence.db_load_records(start, end)
        assert loaded1 == 5
        assert len(sequence.records) == 5

        loaded2 = sequence.db_load_records(start, end)
        assert loaded2 == 0
        assert len(sequence.records) == 5  # no duplicates

    # ------------------------------------------------------------------
    # Staged expansion (left + right window growth)
    # ------------------------------------------------------------------

    def test_staged_window_expansion(self, database_instance):
        sequence = SampleDataSequence()
        sequence.load()
        sequence.database = database_instance

        base = to_datetime("2024-01-01T00:00:00Z")

        for i in range(50):
            sequence.insert_by_datetime(
                SampleDataRecord(
                    date_time=base.add(hours=i),
                    temperature=10.0 + i,
                )
            )

        sequence.db_save_records(clear_memory=True)
        sequence = self._restart_sequence(sequence)

        # load middle window
        mid_start = base.add(hours=20)
        mid_end = base.add(hours=30)

        assert sequence.db_load_records(mid_start, mid_end) == 10
        assert len(sequence.records) == 10

        # expand left
        left_start = base.add(hours=10)
        assert sequence.db_load_records(left_start, mid_start) == 10
        assert len(sequence.records) == 20

        # expand right
        right_end = base.add(hours=40)
        assert sequence.db_load_records(mid_end, right_end) == 10
        assert len(sequence.records) == 30

        # ensure no duplicates
        assert len({r.date_time for r in sequence.records}) == 30

    # ------------------------------------------------------------------
    # db_ensure_loaded behavior
    # ------------------------------------------------------------------

    def test_db_ensure_loaded(self, database_instance):
        sequence = SampleDataSequence()
        sequence.load()
        sequence.database = database_instance

        base = to_datetime("2024-01-01T00:00:00Z")

        for i in range(24):
            sequence.insert_by_datetime(
                SampleDataRecord(
                    date_time=base.add(hours=i),
                    temperature=18.0,
                )
            )

        sequence.db_save_records(clear_memory=True)
        sequence = self._restart_sequence(sequence)

        start = base.add(hours=3)
        end = base.add(hours=8)

        sequence.db_ensure_loaded(start, end)

        assert len(sequence.records) == 5
        assert sequence.db_count_records() == 24

    # ------------------------------------------------------------------
    # Save new records after partial load
    # ------------------------------------------------------------------

    def test_save_after_partial_load(self, database_instance):
        sequence = SampleDataSequence()
        sequence.load()
        sequence.database = database_instance

        base = to_datetime("2024-01-01T00:00:00Z")

        for i in range(10):
            sequence.insert_by_datetime(
                SampleDataRecord(
                    date_time=base.add(hours=i),
                    temperature=10.0,
                )
            )

        sequence.db_save_records(clear_memory=True)
        sequence = self._restart_sequence(sequence)

        # load part
        sequence.db_load_records(base, base.add(hours=5))
        assert len(sequence.records) == 5

        # insert new record beyond existing range
        new_dt = base.add(hours=20)
        sequence.insert_by_datetime(
            SampleDataRecord(date_time=new_dt, temperature=99.0)
        )

        saved = sequence.db_save_records()
        assert saved == 1

        assert sequence.db_count_records() == 11
